# 보호 대상 백엔드 서버 주소 (게이트웨이가 정상 트래픽을 이쪽으로 전달)
TARGET_SERVICE_URL=http://localhost:8080

# Rate Limiting 기준 (몇 초 안에 몇 번까지 허용할지)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=30

# 로그인 실패 카운터를 요청 대비 정확히 세기 위한 브루트포스 기준
BRUTE_FORCE_MAX_FAILURES=5
BRUTE_FORCE_WINDOW_SECONDS=300

# CORS 허용 도메인 (콤마로 구분, 절대 "*" 쓰지 말 것)
ALLOWED_ORIGINS_RAW=http://localhost:5173,http://localhost:3000

# 우리가 실제로 운영하는 리버스 프록시(Traefik 등)의 IP (콤마로 구분)
# 비워두면 X-Forwarded-For 헤더를 아예 무시함 (로컬 개발 시엔 비워둬도 무방)
TRUSTED_PROXIES_RAW=

# 로그 저장 파일 경로
ATTACK_LOG_PATH=./data/attack_log.jsonl
BLACKLIST_PATH=./data/blacklist.json
